{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "Umbraco": {
    "CMS": {
      "Content": {
        "MacroErrors": "Throw"
      },
      "Hosting": {
        "Debug": true
      },
      "Unattended": {
        "UpgradeUnattended": true,
        "InstallUnattended": true,
        "UnattendedUserEmail": "admin@example.com",
        "UnattendedUserPassword": "1234567890",
        "UnattendedUserName": "admin",
        "PackageMigrationsUnattended": true
      }
    }
  },
  "MYA": {
    "RP": {      
      "Enabled": true,
      "Code": "alpha",
      "Rules": {
        "Rules": [
          {
            "Name": "Swagger",
            "Enabled": true,
            "Pattern": "^\/umbraco\/(?!swagger).*$",
            "AppliesTo": "Path"
          }
        ]
      },
      "Response": {
        "ResponseType": "StaticFile",
        "Destination": "error.html",
        "StatusCode": 200
      }

    }
  }
}
