{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
        "Microsoft.AspNetCore": "Warning",
        "Moriyama.PreviewAuth": "Debug"
    }
  },
    "AllowedHosts": "*",
    "MYA": {
        "PA": {
            "Enabled": true,
            "Code": "alpha",
            "Rules": {
                "Rules": [
                    {
                        "Name": "Swagger",
                        "Enabled": true,
                        "Pattern": "^\/(?!swagger).*$",
                        "AppliesTo" :  "Path"
                    }
                ]
            }
            
        }
    }
}
